# 应用配置
APP_NAME=家校互通平台
DEBUG=true

# MySQL数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=school_comm

# JWT配置（生产环境必须修改）
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS配置（多个域名用逗号分隔）
CORS_ORIGINS=*
