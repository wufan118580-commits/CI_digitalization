# 应用配置
APP_NAME=家校互通平台
DEBUG=true

# MySQL数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=school_comm

# JWT配置（生产环境必须修改）
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS配置（多个域名用逗号分隔）
CORS_ORIGINS=*
